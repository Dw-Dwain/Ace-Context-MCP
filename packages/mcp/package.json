{
  "name": "@ace/mcp",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ace-mcp": "./bin/ace-mcp.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ace/core": "workspace:*",
    "@ace/embeddings": "workspace:*",
    "@ace/store": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "license": "Apache-2.0",
  "description": "MCP server exposing the context store to any chat client",
  "author": "Dwain",
  "publishConfig": {
    "access": "public"
  }
}
