{
  "name": "@ace/pipeline",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ace/core": "workspace:*",
    "@ace/cache": "workspace:*",
    "@ace/compress": "workspace:*",
    "@ace/observe": "workspace:*",
    "@ace/optimize": "workspace:*",
    "@ace/policy": "workspace:*",
    "@ace/router": "workspace:*",
    "@ace/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "license": "Apache-2.0",
  "description": "One-call assembly of the full ACE chat pipeline",
  "author": "Dwain",
  "publishConfig": {
    "access": "public"
  }
}
