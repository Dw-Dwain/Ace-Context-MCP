{
  "name": "ace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AI Context Engine — persistent local-first context store any chat can save into and any other can load from.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "test": "pnpm -r --filter=./packages/* test",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "demo:m1": "tsx demos/M1.ts",
    "demo:m2": "tsx demos/M2.ts",
    "demo:m3": "tsx demos/M3.ts",
    "demo:m4": "pnpm -r build && tsx demos/M4.ts",
    "demo:m5": "tsx demos/M5.ts",
    "demo:m6": "tsx demos/M6.ts",
    "demo:m8": "tsx demos/M8.ts",
    "demo:m9": "tsx demos/M9.ts",
    "demo:m11": "tsx demos/M11.ts",
    "serve": "pnpm --filter=@ace/server build && node apps/server/dist/main.js",
    "enable:semantic": "pnpm add -w @huggingface/transformers",
    "setup:global": "pnpm -r build && npm link ./packages/mcp && npm link ./packages/cli"
  },
  "dependencies": {
    "@ace/cache": "workspace:*",
    "@ace/core": "workspace:*",
    "@ace/mcp": "workspace:*",
    "@ace/optimize": "workspace:*",
    "@ace/policy": "workspace:*",
    "@ace/router": "workspace:*",
    "@ace/security": "workspace:*",
    "@ace/store": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
